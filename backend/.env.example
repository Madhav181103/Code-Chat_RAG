# The port FastAPI server will run on
PORT=8000

# Your Google Gemini API Key (required for embeddings and text generation)
GEMINI_API_KEY=

# Directory to persist ChromaDB vector data
CHROMA_PERSIST_DIR=./chroma_store

# Directory where GitHub repositories will be cloned
CLONE_DIR=./cloned_repos

# Maximum file size in KB to process. Large files (e.g. minified JS, binaries)
# are skipped to prevent waste of embedding tokens and indexing overhead.
MAX_FILE_SIZE_KB=500
